# Autoppia Leaderboard API Configuration

# Application Settings
APP_NAME=Autoppia Leaderboard API
DEBUG=false
# Disable request authentication checks in local/testing environments only.
TESTING=false
HOST=0.0.0.0
PORT=8080

# Authentication
# Comma-separated list of API keys
API_KEYS=["dev-token-123","staging-456","prod-789"]

# Validator Authentication
VALIDATOR_AUTH_MESSAGE=I am a honest validator
MIN_VALIDATOR_STAKE=50000
VALIDATOR_NETUID=36
# SUBTENSOR_NETWORK=finney
# SUBTENSOR_ENDPOINT=wss://test.finney.opentensor.ai:443
VALIDATOR_AUTH_CACHE_TTL=180

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=[
  "https://leaderboard.autoppia.com",
  "https://dev-infinitewebarena.autoppia.com",
  "https://infinitewebarena.autoppia.com"
]

# Idempotency Configuration
IDEMPOTENCY_TTL=600

# AWS S3 Storage
# These credentials should be set on the deployment environment only.
AWS_REGION=eu-west-1
AWS_S3_BUCKET=autoppia-subnet
AWS_S3_GIF_PREFIX=gifs
AWS_S3_PUBLIC_BASE_URL=https://autoppia-subnet.s3.eu-west-1.amazonaws.com
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=optional-session-token
