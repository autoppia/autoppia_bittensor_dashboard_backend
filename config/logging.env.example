# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Add these variables to your .env file to enable detailed logging

# ──────────────────────────────────────────────────────────────────────────
# General Logging Levels
# ──────────────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO                    # General application log level
SQLALCHEMY_LOG_LEVEL=ERROR        # Database queries (set to DEBUG to see SQL)
BITTENSOR_LOG_LEVEL=WARNING       # Bittensor library
UVICORN_LOG_LEVEL=INFO            # Web server
UVICORN_ACCESS_LOG=false          # Show Uvicorn access logs

# ──────────────────────────────────────────────────────────────────────────
# File Logging (Recommended for Production)
# ──────────────────────────────────────────────────────────────────────────
LOG_TO_FILE=true                  # Enable logging to files
LOG_FILE_PATH=logs/app.log        # Path to main log file

# Files created:
# - logs/app.log              (main application logs)
# - logs/requests.log         (detailed request/response logs)
# - logs/app.log.YYYY-MM-DD   (daily rotation backups, kept for 30 days)
# - logs/requests.log.YYYY-MM-DD

# ──────────────────────────────────────────────────────────────────────────
# Detailed Request/Response Logging (For Debugging)
# ──────────────────────────────────────────────────────────────────────────
LOG_REQUEST_BODY=true             # Log incoming request payloads
LOG_RESPONSE_BODY=true            # Log outgoing response data

# WARNING: Enabling these will log ALL request/response data including
# sensitive information. Use only in development or for debugging.

# ──────────────────────────────────────────────────────────────────────────
# Recommended Configurations by Environment
# ──────────────────────────────────────────────────────────────────────────

# DEVELOPMENT:
# LOG_LEVEL=DEBUG
# LOG_TO_FILE=true
# LOG_REQUEST_BODY=true
# LOG_RESPONSE_BODY=true

# PRODUCTION:
# LOG_LEVEL=INFO
# LOG_TO_FILE=true
# LOG_REQUEST_BODY=false
# LOG_RESPONSE_BODY=false

# DEBUGGING PRODUCTION ISSUES:
# LOG_LEVEL=DEBUG
# LOG_TO_FILE=true
# LOG_REQUEST_BODY=true
# LOG_RESPONSE_BODY=true
# (Remember to disable after debugging!)

